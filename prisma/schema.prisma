generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                           String                 @id @default(cuid())
  email                        String                 @unique
  passwordHash                 String
  firstName                    String
  lastName                     String
  avatarUrl                    String?
  role                         Role                   @default(STUDENT)
  status                       UserStatus             @default(ACTIVE)
  createdAt                    DateTime               @default(now())
  updatedAt                    DateTime               @updatedAt
  tenantId                     String?
  postedCompanies              Company[]              @relation("CompanyPostedBy")
  coursesTaught                Course[]               @relation("CourseInstructor")
  enrollments                  Enrollment[]
  forumPosts                   ForumPost[]
  forumThreads                 ForumThread[]
  jobAlerts                    JobAlert[]
  jobApplications              JobApplication[]
  jobOpportunitiesPosted       JobOpportunity[]       @relation("JobPostedBy")
  newsPosts                    News[]
  notifications                Notification[]
  profile                      Profile?
  resumes                      Resume[]
  createdInvites               TenantInvite[]         @relation("InviteCreator")
  tenant                       Tenant?                @relation(fields: [tenantId], references: [id])
  volunteerApps                VolunteerApplication[]
  volunteerOpportunitiesPosted VolunteerOpportunity[] @relation("VolunteerPostedBy")
  exams                        Exam[]                 @relation("ExamCreatedBy")
  threadReads                  ThreadRead[]
  threadMentions               ThreadMention[]
  jobSaves                     JobSave[]
  chatMemberships              ChatMembership[]
  chatThreads                  ChatThread[]           @relation("ThreadCreator")
  chatMessages                 ChatMessage[]
  chatNotifications            ChatNotification[]
  chatReadReceipts             ChatReadReceipt[]
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  headline  String?
  bio       String?
  location  String?
  skills    String[] @default([])
  interests String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model Course {
  id                   String        @id @default(cuid())
  slug                 String        @unique
  title                String
  tagline              String
  description          String
  level                CourseLevel
  category             String
  coverImage           String
  certificateAvailable Boolean       @default(false)
  instructorId         String
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  outcomes             String[]      @default([])
  skills               String[]      @default([])
  instructor           User          @relation("CourseInstructor", fields: [instructorId], references: [id])
  enrollments          Enrollment[]
  forumThreads         ForumThread[]
  chatSpaces           ChatSpace[]
  lessons              Lesson[]
  exams                Exam[]
}

model Lesson {
  id              String           @id @default(cuid())
  courseId        String
  title           String
  slug            String
  order           Int
  durationMinutes Int
  format          LessonFormat
  summary         String
  content         String?
  videoUrl        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  forumPosts      ForumPost[]
  chatThreads     ChatThread[]
  course          Course           @relation(fields: [courseId], references: [id])
  lessonProgress  LessonProgress[]
  resources       LessonResource[]

  @@unique([courseId, slug])
  @@index([courseId, order])
}

model LessonResource {
  id       String       @id @default(cuid())
  lessonId String
  title    String
  type     ResourceType
  url      String
  lesson   Lesson       @relation(fields: [lessonId], references: [id])
}

model Exam {
  id           String     @id @default(cuid())
  courseId     String
  createdById  String
  type         ExamType
  status       ExamStatus @default(DRAFT)
  title        String
  description  String?
  sectionId    String?
  sectionLabel String?
  passingScore Int?
  timeLimit    Int?
  modules      Json       @default("[]")
  version      Int        @default(1)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  course    Course @relation(fields: [courseId], references: [id])
  createdBy User   @relation("ExamCreatedBy", fields: [createdById], references: [id])

  @@index([courseId, status])
  @@index([createdById, status])
}

model Enrollment {
  id                 String           @id @default(cuid())
  userId             String
  courseId           String
  status             EnrollmentStatus @default(ACTIVE)
  progressPercentage Int              @default(0)
  lastAccessedAt     DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  course             Course           @relation(fields: [courseId], references: [id])
  user               User             @relation(fields: [userId], references: [id])
  lessonProgress     LessonProgress[]

  @@unique([userId, courseId])
}

model LessonProgress {
  id           String               @id @default(cuid())
  enrollmentId String
  lessonId     String
  status       LessonProgressStatus @default(NOT_STARTED)
  completedAt  DateTime?
  enrollment   Enrollment           @relation(fields: [enrollmentId], references: [id])
  lesson       Lesson               @relation(fields: [lessonId], references: [id])

  @@unique([enrollmentId, lessonId])
}

model ForumThread {
  id        String          @id @default(cuid())
  courseId  String
  authorId  String
  title     String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  author    User            @relation(fields: [authorId], references: [id])
  course    Course          @relation(fields: [courseId], references: [id])
  posts     ForumPost[]
  reads     ThreadRead[]
  mentions  ThreadMention[]
}

model ForumPost {
  id        String      @id @default(cuid())
  threadId  String
  authorId  String
  lessonId  String?
  parentId  String?
  content   String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  author    User        @relation(fields: [authorId], references: [id])
  lesson    Lesson?     @relation(fields: [lessonId], references: [id])
  parent    ForumPost?  @relation("PostReplies", fields: [parentId], references: [id])
  replies   ForumPost[] @relation("PostReplies")
  thread    ForumThread @relation(fields: [threadId], references: [id])
}

model Resume {
  id              String             @id @default(cuid())
  userId          String
  title           String
  summary         String?
  skills          String[]           @default([])
  slug            String             @unique
  visibility      ResumeVisibility   @default(PRIVATE)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  jobApplications JobApplication[]
  user            User               @relation(fields: [userId], references: [id])
  experiences     ResumeExperience[]
  projects        ResumeProject[]
}

model ResumeExperience {
  id           String    @id @default(cuid())
  resumeId     String
  company      String
  role         String
  startDate    DateTime
  endDate      DateTime?
  description  String?
  achievements String[]  @default([])
  order        Int       @default(0)
  resume       Resume    @relation(fields: [resumeId], references: [id])
}

model ResumeProject {
  id        String   @id @default(cuid())
  resumeId  String
  name      String
  summary   String?
  link      String?
  techStack String[] @default([])
  order     Int      @default(0)
  resume    Resume   @relation(fields: [resumeId], references: [id])
}

model JobOpportunity {
  id               String           @id @default(cuid())
  title            String
  company          String
  location         String
  country          String
  jobType          JobType
  remoteOption     RemoteOption
  salaryRange      String?
  description      String?
  requirements     String[]         @default([])
  tags             String[]         @default([])
  postedById       String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  applicationCount Int              @default(0)
  deadline         DateTime?
  featured         Boolean          @default(false)
  isActive         Boolean          @default(true)
  slug             String?          @unique
  viewCount        Int              @default(0)
  applications     JobApplication[]
  saves            JobSave[]
  postedBy         User?            @relation("JobPostedBy", fields: [postedById], references: [id])
}

model JobApplication {
  id               String               @id @default(cuid())
  userId           String
  jobOpportunityId String
  resumeId         String?
  status           JobApplicationStatus @default(SUBMITTED)
  submittedAt      DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  coverLetter      String?
  opportunity      JobOpportunity       @relation(fields: [jobOpportunityId], references: [id])
  resume           Resume?              @relation(fields: [resumeId], references: [id])
  user             User                 @relation(fields: [userId], references: [id])
}

model JobSave {
  id               String   @id @default(cuid())
  userId           String
  jobOpportunityId String
  createdAt        DateTime @default(now())

  user           User           @relation(fields: [userId], references: [id])
  jobOpportunity JobOpportunity @relation(fields: [jobOpportunityId], references: [id])

  @@unique([userId, jobOpportunityId])
}

model Company {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  website     String?
  logo        String?
  size        String?
  industry    String?
  location    String?
  postedById  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  postedBy    User?    @relation("CompanyPostedBy", fields: [postedById], references: [id])
}

model JobAlert {
  id        String   @id @default(cuid())
  userId    String
  keywords  String[]
  location  String?
  jobType   JobType?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model VolunteerOpportunity {
  id           String                 @id @default(cuid())
  title        String
  organization String
  location     String
  country      String
  description  String?
  commitment   String?
  skills       String[]               @default([])
  isRemote     Boolean                @default(false)
  postedById   String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  applications VolunteerApplication[]
  postedBy     User?                  @relation("VolunteerPostedBy", fields: [postedById], references: [id])
}

model VolunteerApplication {
  id                     String                     @id @default(cuid())
  userId                 String
  volunteerOpportunityId String
  status                 VolunteerApplicationStatus @default(SUBMITTED)
  submittedAt            DateTime                   @default(now())
  user                   User                       @relation(fields: [userId], references: [id])
  opportunity            VolunteerOpportunity       @relation(fields: [volunteerOpportunityId], references: [id])
}

model News {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  content     String
  summary     String?
  tags        String[]
  status      String    @default("DRAFT")
  authorId    String
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  author      User      @relation(fields: [authorId], references: [id])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  payload   Json
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])
}

model ThreadRead {
  id         String   @id @default(cuid())
  userId     String
  threadId   String
  lastReadAt DateTime @default(now())
  createdAt  DateTime @default(now())

  user   User        @relation(fields: [userId], references: [id])
  thread ForumThread @relation(fields: [threadId], references: [id])

  @@unique([userId, threadId])
  @@index([threadId])
}

model ThreadMention {
  id        String   @id @default(cuid())
  userId    String
  threadId  String
  createdAt DateTime @default(now())

  user   User        @relation(fields: [userId], references: [id])
  thread ForumThread @relation(fields: [threadId], references: [id])

  @@index([userId])
  @@index([threadId])
}

model Tenant {
  id               String          @id @default(cuid())
  name             String
  slug             String          @unique
  contactName      String?
  contactEmail     String?
  logoUrl          String?
  planTier         TenantPlanTier  @default(PROFESSIONAL)
  status           TenantStatus    @default(ACTIVE)
  seatLimit        Int             @default(100)
  seatAllocated    Int             @default(0)
  licenseExpiresAt DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  archivedAt       DateTime?
  invites          TenantInvite[]
  settings         TenantSettings?
  usage            TenantUsage[]
  users            User[]
  chatSpaces       ChatSpace[]
}

model TenantSettings {
  id             String   @id @default(cuid())
  tenantId       String   @unique
  primaryColor   String?  @default("#4f46e5")
  secondaryColor String?  @default("#2dd4bf")
  featureFlags   Json     @default("{}")
  themeOverrides Json?
  domain         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
}

model TenantInvite {
  id          String       @id @default(cuid())
  tenantId    String
  email       String
  role        Role
  token       String       @unique
  status      InviteStatus @default(PENDING)
  expiresAt   DateTime
  createdById String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  createdBy   User?        @relation("InviteCreator", fields: [createdById], references: [id])
  tenant      Tenant       @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
}

model TenantUsage {
  id             String   @id @default(cuid())
  tenantId       String
  year           Int
  month          Int
  activeStudents Int      @default(0)
  activeTutors   Int      @default(0)
  activeJobs     Int      @default(0)
  storageUsedMb  Int      @default(0)
  applications   Int      @default(0)
  createdAt      DateTime @default(now())
  tenant         Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, year, month])
}

model ChatSpace {
  id         String         @id @default(cuid())
  tenantId   String
  courseId   String?
  slug       String         @unique
  title      String
  visibility ChatVisibility @default(COURSE_ONLY)
  settings   Json           @default("{}")
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  course      Course?          @relation(fields: [courseId], references: [id])
  memberships ChatMembership[]
  threads     ChatThread[]

  @@index([tenantId, courseId])
}

model ChatMembership {
  id          String    @id @default(cuid())
  chatSpaceId String
  userId      String
  role        ChatRole  @default(STUDENT)
  mutedUntil  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  chatSpace ChatSpace @relation(fields: [chatSpaceId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([chatSpaceId, userId])
}

model ChatThread {
  id            String         @id @default(cuid())
  chatSpaceId   String
  createdById   String
  type          ChatThreadType @default(CHANNEL)
  title         String?
  lessonId      String?
  lastMessageAt DateTime?
  archivedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  chatSpace        ChatSpace          @relation(fields: [chatSpaceId], references: [id])
  createdBy        User               @relation("ThreadCreator", fields: [createdById], references: [id])
  lesson           Lesson?            @relation(fields: [lessonId], references: [id])
  messages         ChatMessage[]
  reads            ChatReadReceipt[]
  ChatNotification ChatNotification[]

  @@index([chatSpaceId, type])
  @@index([lessonId])
}

model ChatMessage {
  id          String    @id @default(cuid())
  threadId    String
  authorId    String
  parentId    String?
  content     String
  attachments Json      @default("[]")
  mentions    Json      @default("[]")
  sentAt      DateTime  @default(now())
  editedAt    DateTime?
  deletedAt   DateTime?

  thread        ChatThread         @relation(fields: [threadId], references: [id])
  author        User               @relation(fields: [authorId], references: [id])
  parent        ChatMessage?       @relation("MessageReplies", fields: [parentId], references: [id])
  replies       ChatMessage[]      @relation("MessageReplies")
  notifications ChatNotification[]

  @@index([threadId, sentAt])
}

model ChatReadReceipt {
  id         String   @id @default(cuid())
  threadId   String
  userId     String
  lastReadAt DateTime @default(now())

  thread ChatThread @relation(fields: [threadId], references: [id])
  user   User       @relation(fields: [userId], references: [id])

  @@unique([threadId, userId])
}

model ChatNotification {
  id        String               @id @default(cuid())
  userId    String
  threadId  String
  messageId String
  type      ChatNotificationType
  sentAt    DateTime             @default(now())
  seenAt    DateTime?

  user    User        @relation(fields: [userId], references: [id])
  thread  ChatThread  @relation(fields: [threadId], references: [id])
  message ChatMessage @relation(fields: [messageId], references: [id])

  @@index([userId, seenAt])
}

enum Role {
  STUDENT
  TUTOR
  ADMIN
  SUPER_ADMIN
  EMPLOYER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  INVITED
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum LessonFormat {
  VIDEO
  LIVE
  TEXT
  PROJECT
}

enum ResourceType {
  PDF
  SLIDE
  LINK
  CODE
  VIDEO
  SHEET
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  WITHDRAWN
}

enum LessonProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum ResumeVisibility {
  PRIVATE
  NETWORK
  PUBLIC
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

enum RemoteOption {
  REMOTE
  HYBRID
  ONSITE
}

enum JobApplicationStatus {
  SUBMITTED
  REVIEWING
  INTERVIEW
  OFFER
  REJECTED
}

enum VolunteerApplicationStatus {
  SUBMITTED
  CONFIRMED
  COMPLETED
  WITHDRAWN
}

enum NotificationType {
  ENROLLMENT_UPDATE
  LESSON_RELEASE
  FORUM_REPLY
  APPLICATION_STATUS
  SYSTEM
}

enum ExamStatus {
  DRAFT
  SUBMITTED
  APPROVED
  CHANGES
}

enum ExamType {
  SECTION
  FINAL
}

enum TenantStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  CANCELLED
}

enum TenantPlanTier {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum ChatVisibility {
  COURSE_ONLY
  TENANT_WIDE
}

enum ChatRole {
  STUDENT
  TUTOR
  ADMIN
  GUEST
}

enum ChatThreadType {
  CHANNEL
  LESSON
  ANNOUNCEMENT
  DM
}

enum ChatNotificationType {
  MENTION
  REPLY
  ANNOUNCEMENT
}
